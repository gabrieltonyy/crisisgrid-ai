DATABASE_URL=postgresql://crisisgrid:crisisgrid_password@localhost:5432/crisisgrid
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crisisgrid
POSTGRES_USER=crisisgrid
POSTGRES_PASSWORD=crisisgrid_password

JWT_SECRET=replace_with_secure_random_value
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000,https://crisisgrid-ai.vercel.app
UPLOAD_DIR=uploads

CLOUDANT_ENABLED=false
CLOUDANT_URL=
CLOUDANT_API_KEY=
CLOUDANT_DB_REPORTS=crisis_reports_raw
CLOUDANT_DB_AGENT_LOGS=agent_payload_logs
CLOUDANT_DB_AUDIT_EVENTS=audit_events

WATSONX_ENABLED=false
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# NEW - watsonx Orchestrate / local orchestration control plane
# Orchestration Control Plane
ORCHESTRATE_ENABLED=true
ORCHESTRATE_MODE=local
ORCHESTRATE_API_URL=your_watsonx_orchestrate_url
ORCHESTRATE_API_KEY=your_watsonx_orchestrate_apikey
ORCHESTRATE_IAM_URL=https://iam.cloud.ibm.com/identity/token
ORCHESTRATE_PIPELINE_ID=crisisgrid-main-pipeline
ORCHESTRATE_PIPELINE_CONFIG=orchestration/pipeline.yaml

# Agent execution controls
AGENT_TIMEOUT_SECONDS=30
AGENT_MAX_RETRIES=3
AGENT_CONFIDENCE_THRESHOLD=0.6
AGENT_PRIORITY_THRESHOLD=P2
ENABLE_AGENT_AUDIT_LOGS=true
ENABLE_AGENT_RATE_LIMIT=true
AGENT_RATE_LIMIT_PER_MINUTE=60

# NEW - Kafka / event bus (last priority)
KAFKA_ENABLED=false
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=crisisgrid-backend
KAFKA_GROUP_ID=crisisgrid-orchestrator
KAFKA_TOPIC_REPORT_CREATED=reports.created
KAFKA_TOPIC_INCIDENT_UPDATED=incidents.updated
KAFKA_TOPIC_ALERT_TRIGGERED=alerts.triggered

MAPS_PROVIDER=mock
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

WEATHER_ENABLED=false
WEATHER_API_PROVIDER=simulated
WEATHER_API_KEY=
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

SMS_ENABLED=false
SMS_PROVIDER=simulated
ENABLE_SIMULATED_DISPATCH=true
ENABLE_SIMULATED_VERIFICATION=true
ENABLE_DEMO_SEED_DATA=true
