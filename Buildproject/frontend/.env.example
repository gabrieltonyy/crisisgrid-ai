# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Map Configuration
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors

# Default Map Center (coordinates for initial view)
NEXT_PUBLIC_DEFAULT_LAT=51.5074
NEXT_PUBLIC_DEFAULT_LNG=-0.1278
NEXT_PUBLIC_DEFAULT_ZOOM=10

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=true

# Refresh Intervals (in milliseconds)
NEXT_PUBLIC_ALERT_REFRESH_INTERVAL=30000
NEXT_PUBLIC_DISPATCH_REFRESH_INTERVAL=60000